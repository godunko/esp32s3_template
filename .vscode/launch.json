{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "gdbtarget",
      "request": "attach",
      "name": "Eclipse CDT GDB Adapter",
      "initCommands": [
        "monitor reset halt",
        "hbreak __gnat_last_chance_handler",
        "hbreak _ada_main"
      ]
    },
    {
      "type": "espidf",
      "name": "Launch",
      "request": "launch"
    }
  ]
}